# Copy to .env on the VPS and fill in. Never commit .env.
# chmod 600 .env after editing.

# GitHub user/org that owns the GHCR image (lowercase).
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# Strong, unique password — generate with `openssl rand -base64 32`
DB_PASSWORD=replace-me

# First admin account, seeded on first boot only (skipped if any users exist).
# The user is forced to change this password on first login.
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=replace-me-strong

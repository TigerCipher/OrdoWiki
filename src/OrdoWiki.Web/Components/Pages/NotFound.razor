@page "/not-found"
@layout MainLayout

<PageTitle>Page not found</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="2">
        <MudIcon Icon="@Icons.Material.Filled.SearchOff"
                 Color="Color.Warning"
                 Size="Size.Large"
                 Class="mb-4"
                 Style="font-size: 4rem;"/>

        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2">Page not found</MudText>

        <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-6 mud-text-secondary">
            The page you're looking for doesn't exist or has moved.
        </MudText>

        <MudButton Href="/"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Home">
            Back to home
        </MudButton>
    </MudPaper>
</MudContainer>

@page "/gallery"
@using Microsoft.AspNetCore.Authorization
@using OrdoWiki.Data.Auth
@using OrdoWiki.Data.Entities
@using OrdoWiki.Web.Components.Shared

@rendermode InteractiveServer

@attribute [Authorize]

<PageTitle>OrdoWiki | Gallery</PageTitle>

<SectionContent SectionName="page-header">
    <MudText Typo="Typo.h4" Class="fill-space">Gallery</MudText>
</SectionContent>

<div class="GalleryList y-stack gap-4">
    <div class="filters x-stack gap-3 align-center wrap">
        <MudChipSet T="MediaSourceType?"
                    SelectedValue="_filter.SourceType"
                    SelectedValueChanged="OnSourceFilterChanged"
                    CheckMark="true"
                    SelectionMode="SelectionMode.SingleSelection">
            <MudChip T="MediaSourceType?" Value="@((MediaSourceType?)null)">All</MudChip>
            <MudChip T="MediaSourceType?" Value="@((MediaSourceType?)MediaSourceType.WikiPage)">Pages</MudChip>
            <MudChip T="MediaSourceType?" Value="@((MediaSourceType?)MediaSourceType.Character)">Characters</MudChip>
            <MudChip T="MediaSourceType?" Value="@((MediaSourceType?)MediaSourceType.Standalone)">Standalone</MudChip>
        </MudChipSet>

        <MudAutocomplete T="UserDto"
                         Class="uploader-filter"
                         Value="_selectedUploader"
                         ValueChanged="OnUploaderChanged"
                         SearchFunc="SearchUploadersAsync"
                         ToStringFunc="@(u => u?.DisplayName ?? u?.Username ?? string.Empty)"
                         Placeholder="Filter by uploader…"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Clearable="true"
                         CoerceValue="false"
                         CoerceText="false"/>

        <MudSelect T="TagDto"
                   Value="_selectedTag"
                   ValueChanged="OnTagFilterChangedAsync"
                   Label="Tag"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Clearable="true"
                   Class="tag-filter">
            <MudSelectItem T="TagDto" Value="@((TagDto?)null)">All tags</MudSelectItem>
            @foreach (TagDto tag in _allTags)
            {
                <MudSelectItem T="TagDto" Value="@tag">@tag.Name</MudSelectItem>
            }
        </MudSelect>

        <MudButton Class="push-right"
                   OnClick="OpenUploadAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Upload">
            Upload
        </MudButton>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else if (_items.Count == 0)
    {
        <MudText Typo="Typo.body1" Color="Color.Tertiary">
            No images yet.
        </MudText>
    }
    else
    {
        <div class="grid">
            @foreach (GalleryItemDto item in _items)
            {
                <div class="tile">
                    <button type="button" class="tile-button" @onclick="@(() => OpenLightboxAsync(item))">
                        <img src="@item.Asset.StoragePath" alt="@item.Asset.OriginalName" loading="lazy"/>
                    </button>
                    <div class="tile-meta y-stack gap-1">
                        <div class="x-stack align-center gap-1">
                            <AuthorName User="item.Asset.UploadedBy" AvatarSize="Size.Small" Class="fill-space"/>
                            <AuthorizeView Policy="@Policies.CanEdit" Context="auth">
                                <MudIconButton Icon="@Icons.Material.Filled.LocalOffer"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               aria-label="Edit tags"
                                               OnClick="@(() => EditTagsAsync(item))"/>
                            </AuthorizeView>
                        </div>
                        @if (item.Source is not null)
                        {
                            <a class="source-link" href="@item.Source.Url">
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                    from @item.Source.Kind: @item.Source.Name
                                </MudText>
                            </a>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">Standalone</MudText>
                        }
                        @if (item.Tags.Count > 0)
                        {
                            <div class="tile-tags x-stack gap-1 wrap">
                                @foreach (TagDto tag in item.Tags)
                                {
                                    <MudChip T="string"
                                             Color="Color.Secondary"
                                             Size="Size.Small"
                                             Variant="Variant.Outlined"
                                             Href="@($"/gallery?tag={tag.Slug}")">
                                        @tag.Name
                                    </MudChip>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @if (_pageCount > 1)
        {
            <div class="x-stack justify-center">
                <MudPagination Count="_pageCount" Selected="_filter.Page" SelectedChanged="OnPageChanged"/>
            </div>
        }
    }
</div>

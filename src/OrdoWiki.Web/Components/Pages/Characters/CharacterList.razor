@page "/characters"
@using Microsoft.AspNetCore.Authorization
@using OrdoWiki.Web.Components.Shared

@rendermode InteractiveServer

<PageTitle>OrdoWiki | Characters</PageTitle>

<SectionContent SectionName="page-header">
    <div class="x-stack gap-2 align-center">
        <MudText Typo="Typo.h4" Class="fill-space">Characters</MudText>
        <AuthorizeView>
            <MudButton Href="/characters/mine"
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Person">
                My characters
            </MudButton>
        </AuthorizeView>
    </div>
</SectionContent>

<div class="CharacterList y-stack gap-6">
    <div class="x-stack gap-2 align-center wrap">
        <MudTextField @bind-Value="_search"
                      @bind-Value:after="OnSearchChanged"
                      Placeholder="Search by user or character name…"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      DebounceInterval="200"
                      Clearable="true"
                      Class="search-field"/>

        <MudSelect T="TagDto"
                   Value="_selectedTag"
                   ValueChanged="OnTagFilterChangedAsync"
                   Label="Filter by tag"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Clearable="true"
                   Class="tag-filter">
            <MudSelectItem T="TagDto" Value="@((TagDto?)null)">All tags</MudSelectItem>
            @foreach (TagDto tag in _allTags)
            {
                <MudSelectItem T="TagDto" Value="@tag">@tag.Name</MudSelectItem>
            }
        </MudSelect>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else if (_filteredGroups.Count == 0)
    {
        <MudText Typo="Typo.body1" Color="Color.Tertiary">
            @(string.IsNullOrWhiteSpace(_search) ? "No characters yet." : "No matches.")
        </MudText>
    }
    else
    {
        @foreach (CharacterGroup group in _pageGroups)
        {
            <section class="owner-group y-stack gap-3">
                <div class="x-stack gap-2 align-center">
                    <AuthorName User="group.Owner"/>
                    <MudText Typo="Typo.caption" Color="Color.Tertiary">@group.Characters.Count character@(group.Characters.Count == 1 ? "" : "s")</MudText>
                    @if (ShowExpandLink(group))
                    {
                        <MudLink Class="push-right see-all"
                                 Color="Color.Primary"
                                 Typo="Typo.body2"
                                 OnClick="@(() => ToggleExpanded(group.Owner!.Id))">
                            @(IsExpanded(group)
                                ? "Show less"
                                : $"See all ({group.Characters.Count})")
                        </MudLink>
                    }
                </div>

                <div class="character-row">
                    @foreach (CharacterDto character in VisibleCharacters(group))
                    {
                        <a class="character-card" href="@($"/characters/{character.Slug}")">
                            <div class="thumb">
                                @{
                                    CharacterImageDto? thumb = character.Images.FirstOrDefault();
                                }
                                @if (thumb?.MediaAsset is not null)
                                {
                                    <img src="@thumb.MediaAsset.StoragePath" alt="@character.Name"/>
                                }
                                else
                                {
                                    <div class="placeholder">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large"/>
                                    </div>
                                }
                            </div>
                            <div class="card-body y-stack gap-1">
                                <MudText Typo="Typo.subtitle1">@character.Name</MudText>
                                @if (!string.IsNullOrWhiteSpace(character.Summary))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="summary">@character.Summary</MudText>
                                }
                            </div>
                        </a>
                    }
                </div>
            </section>
        }

        @if (_pageCount > 1)
        {
            <div class="x-stack justify-center">
                <MudPagination Count="_pageCount" Selected="_page" SelectedChanged="OnPageChanged"/>
            </div>
        }
    }
</div>

@page "/characters/mine"
@using Microsoft.AspNetCore.Authorization
@using OrdoWiki.Web.Components.Shared

@rendermode InteractiveServer

@attribute [Authorize]

<PageTitle>OrdoWiki | My Characters</PageTitle>

<SectionContent SectionName="page-header">
    <div class="x-stack gap-2 align-center">
        <MudText Typo="Typo.h4" Class="fill-space">My Characters</MudText>
        <MudButton Href="/characters/new"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@(!_canCreate)">
            New character
        </MudButton>
    </div>
</SectionContent>

<div class="MyCharacters y-stack gap-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else
    {
        @if (!_canCreate && _capInfo is not null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                @_capInfo
            </MudAlert>
        }

        @if (_characters.Count == 0)
        {
            <MudText Typo="Typo.body1" Color="Color.Tertiary">
                You haven't created any characters yet. Click "New character" to start.
            </MudText>
        }
        else
        {
            <div class="card-grid">
                @foreach (CharacterDto character in _characters)
                {
                    <a class="character-card" href="@($"/characters/{character.Slug}")">
                        <div class="thumb">
                            @{
                                CharacterImageDto? thumb = character.Images.FirstOrDefault();
                            }
                            @if (thumb?.MediaAsset is not null)
                            {
                                <img src="@thumb.MediaAsset.StoragePath" alt="@character.Name"/>
                            }
                            else
                            {
                                <div class="placeholder">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large"/>
                                </div>
                            }
                        </div>
                        <div class="card-body y-stack gap-1">
                            <MudText Typo="Typo.subtitle1">@character.Name</MudText>
                            @if (!string.IsNullOrWhiteSpace(character.Summary))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="summary">@character.Summary</MudText>
                            }
                        </div>
                    </a>
                }
            </div>
        }
    }
</div>

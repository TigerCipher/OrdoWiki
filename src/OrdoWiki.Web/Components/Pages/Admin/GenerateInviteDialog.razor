@using OrdoWiki.Data.Auth
<MudDialog>
    <DialogContent>
        <MudSelect T="string"
                   @bind-Value="Role"
                   Label="Assign role"
                   Variant="Variant.Outlined"
                   Class="mb-3">
            @foreach (string role in Roles.All)
            {
                <MudSelectItem Value="@role">@role</MudSelectItem>
            }
        </MudSelect>

        <MudNumericField T="int"
                         @bind-Value="ExpiresInDays"
                         Label="Expires in (days)"
                         Min="1"
                         Max="365"
                         Variant="Variant.Outlined"/>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm">Generate</MudButton>
    </DialogActions>
</MudDialog>

@using OrdoWiki.Data.Calendars
@using OrdoWiki.Web.Models.Requests

<div class="CalendarTab y-stack gap-6">

    <section class="y-stack gap-3">
        <MudText Typo="Typo.h6">Months</MudText>
        <MudText Typo="Typo.body2" Color="Color.Tertiary">
            Rename any month. The rest of the wiki picks up the change immediately.
        </MudText>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
        }
        else
        {
            <MudTable Items="_months" Dense="true" Hover="true" Bordered="false" Striped="true">
                <HeaderContent>
                    <MudTh Style="width: 80px;">#</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh Style="width: 120px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.MonthIndex</MudTd>
                    <MudTd>
                        <MudTextField T="string"
                                      @bind-Value="context.Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="60"/>
                    </MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => RenameMonthAsync(context))">
                            Save
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </section>

    <MudDivider/>

    <section class="y-stack gap-3">
        <div class="x-stack gap-2 align-center">
            <MudText Typo="Typo.h6" Class="fill-space">Eras</MudText>
            <MudButton OnClick="OpenCreateEraAsync"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add">
                New era
            </MudButton>
        </div>
        <MudText Typo="Typo.body2" Color="Color.Tertiary">
            Each era has a short code (shown after the year, e.g. "47 ACW"), an anchor year,
            and a direction. Forward eras count up from the anchor; backward eras count down toward it.
        </MudText>

        @if (!_loading)
        {
            <MudTable Items="_eras" Dense="true" Hover="true" Bordered="false" Striped="true">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Code</MudTh>
                    <MudTh>Anchor year</MudTh>
                    <MudTh>Direction</MudTh>
                    <MudTh>Sort</MudTh>
                    <MudTh Style="width: 180px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Name</MudTd>
                    <MudTd><code>@context.ShortCode</code></MudTd>
                    <MudTd>@context.AnchorYear</MudTd>
                    <MudTd>@context.Direction</MudTd>
                    <MudTd>@context.SortOrder</MudTd>
                    <MudTd>
                        <div class="x-stack gap-1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenEditEraAsync(context))"/>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => DeleteEraAsync(context))"/>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </section>
</div>

<MudDialog>
    <DialogContent>
        <MudText Class="mb-3">
            Temporary password for <strong>@Username</strong>. Send this to them out-of-band — they'll be forced to change it on next sign-in.
        </MudText>
        <MudTextField T="string"
                      Value="@TempPassword"
                      Variant="Variant.Outlined"
                      ReadOnly="true"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="Copy" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled">Done</MudButton>
    </DialogActions>
</MudDialog>

@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using OrdoWiki.Data.Auth
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.Admin)]

<PageTitle>Admin</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Admin</MudText>

<MudTabs Outlined="true" Position="Position.Top" Rounded="true" TabPanelsClass="pa-4">
    <MudTabPanel Text="Users" Icon="@Icons.Material.Filled.People">
        <UsersTab/>
    </MudTabPanel>
    <MudTabPanel Text="Invites" Icon="@Icons.Material.Filled.Email">
        <InvitesTab/>
    </MudTabPanel>
    <MudTabPanel Text="Settings" Icon="@Icons.Material.Filled.Settings">
        <SettingsTab/>
    </MudTabPanel>
</MudTabs>

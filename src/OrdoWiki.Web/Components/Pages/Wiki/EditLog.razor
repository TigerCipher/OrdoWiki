@page "/logs/{Slug}/edit"
@using Microsoft.AspNetCore.Authorization
@using OrdoWiki.Data.Auth
@using OrdoWiki.Data.Entities
@using OrdoWiki.Web.Components.Shared

@rendermode InteractiveServer

@attribute [Authorize(Policies.CanEdit)]

<PageTitle>OrdoWiki | Logs | @_originalTitle</PageTitle>

<SectionContent SectionName="page-header">
    <MudText Typo="Typo.h4">Edit @_originalTitle</MudText>
</SectionContent>

<div class="EditLog y-stack gap-4">

    @if (_loading)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="metadata x-stack gap-2">
            <MudTextField T="string"
                          @bind-Value="@_page.Title"
                          Label="Title"
                          InputType="InputType.Text"
                          MaxLength="200"
                          Variant="Variant.Outlined"/>

            <MudTextField T="string"
                          @bind-Value="@_page.Slug"
                          Label="Slug"
                          InputType="InputType.Text"
                          MaxLength="200"
                          Variant="Variant.Outlined"/>
        </div>
        
        <MudTextField T="string"
                      @bind-Value="@_page.Summary"
                      Label="Summary"
                      Variant="Variant.Outlined"
                      Lines="3"
                      MaxLines="6"
                      MaxLength="500"
                      Sizing="InputSizing.Auto"
                      Placeholder="Summary for this log" />

        <TagPicker Label="Tags" Value="_tagNames" ValueChanged="OnTagsChanged"/>

        <RichContentEditor @bind-Value="@_markdownBody"
                           Format="@_format"
                           ShowFormatToggle="false"
                           Label="Contents"
                           Placeholder="The log contents"
                           SourceType="MediaSourceType.WikiPage"
                           SourceId="@_page.Id"/>

        <RelatedItemsEditor @bind-Value="_related"
                            SelfKind="RelatedItemKind.Log"
                            SelfId="@_page.Id"/>

        <MudTextField T="string"
                      @bind-Value="@_editSummary"
                      Label="Edit Summary"
                      Variant="Variant.Outlined"
                      Lines="3"
                      MaxLines="6"
                      MaxLength="500"
                      Sizing="InputSizing.Auto"
                      Placeholder="Summary for this edit" />
        
        <MudButton Class="push-right" Color="Color.Primary" OnClick="@SaveEditAsync">Save</MudButton>
    }

</div>

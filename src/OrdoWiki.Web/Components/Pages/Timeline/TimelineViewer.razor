@page "/timeline/{Id:guid}"
@using OrdoWiki.Data.Auth
@using OrdoWiki.Web.Components.Shared

@rendermode InteractiveServer

<PageTitle>OrdoWiki | Timeline | @_event.Title</PageTitle>

<SectionContent SectionName="page-header">
    <div class="TimelineViewerHeader x-stack gap-2">
        <MudText Typo="Typo.h4" Class="fill-space">@_event.Title</MudText>
        <AuthorizeView Policy="@Policies.CanEdit">
            <MudButton Href="@($"/timeline/{Id}/edit")"
                       StartIcon="@Icons.Material.Filled.Edit"
                       Color="Color.Primary"
                       Variant="Variant.Filled">
                Edit
            </MudButton>
        </AuthorizeView>
    </div>
</SectionContent>

<div class="TimelineViewer y-stack gap-4">

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else
    {
        <div class="meta y-stack gap-1">
            <div class="meta-row x-stack gap-2 align-center">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Color="Color.Tertiary"/>
                <MudText Typo="Typo.subtitle2">@_event.DisplayDate</MudText>
            </div>
            <div class="meta-row x-stack gap-2">
                <MudText Typo="Typo.caption" Color="Color.Tertiary">Recorded by</MudText>
                <AuthorName User="_event.CreatedBy"/>
                <MudText Typo="Typo.caption" Color="Color.Tertiary">on</MudText>
                <LocalTime DateTime="_event.CreatedAt"/>
            </div>

            @if (_showEditedRow)
            {
                <div class="meta-row x-stack gap-2">
                    <MudText Typo="Typo.caption" Color="Color.Tertiary">Last edited</MudText>
                    <LocalTime DateTime="_event.UpdatedAt"/>
                </div>
            }
        </div>

        @if (_event.Tags.Count > 0)
        {
            <div class="tags x-stack gap-1 align-center wrap">
                @foreach (TagDto tag in _event.Tags)
                {
                    <MudChip T="string"
                             Color="Color.Secondary"
                             Size="Size.Small"
                             Variant="Variant.Outlined"
                             Href="@($"/timeline?tag={tag.Slug}")">
                        @tag.Name
                    </MudChip>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_event.Summary))
        {
            <MudPaper Outlined="true" Class="summary pa-3">
                <MudText Typo="Typo.body1">@_event.Summary</MudText>
            </MudPaper>
        }

        @if (!string.IsNullOrWhiteSpace(_renderedHtml))
        {
            <div class="markdown-body">@((MarkupString)_renderedHtml)</div>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Tertiary">No description.</MudText>
        }

        <div>
            <MudButton Href="/timeline"
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Back to timeline
            </MudButton>
        </div>
    }
</div>

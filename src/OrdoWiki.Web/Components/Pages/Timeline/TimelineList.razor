@page "/timeline"
@using Microsoft.AspNetCore.Authorization
@using OrdoWiki.Data.Auth
@using OrdoWiki.Web.Components.Shared

@rendermode InteractiveServer

@attribute [Authorize]

<PageTitle>OrdoWiki | Timeline</PageTitle>

<SectionContent SectionName="page-header">
    <div class="x-stack gap-2 align-center">
        <MudText Typo="Typo.h4" Class="fill-space">Timeline</MudText>
        <AuthorizeView Policy="@Policies.CanEdit">
            <MudButton Href="/timeline/new"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add">
                New event
            </MudButton>
        </AuthorizeView>
    </div>
</SectionContent>

<div class="TimelineList y-stack gap-3">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else if (_allEvents.Count == 0)
    {
        <MudText Typo="Typo.body1" Color="Color.Tertiary">
            No events yet.
        </MudText>
    }
    else
    {
        <div class="x-stack gap-2 align-center">
            <MudButton OnClick="ToggleSortAsync"
                       Variant="Variant.Outlined"
                       Size="Size.Small"
                       StartIcon="@(_descending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)">
                @(_descending ? "Newest first" : "Oldest first")
            </MudButton>
        </div>

        <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Default">
            @foreach (YearGroup group in _groups)
            {
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <ItemOpposite>
                        <MudText Typo="Typo.h6">@group.YearLabel</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        @foreach (TimelineEventDto ev in group.Events)
                        {
                            <MudPaper Outlined="true" Class="event pa-3 mb-2">
                                <div class="x-stack gap-2 align-center">
                                    <MudText Typo="Typo.subtitle1" Class="fill-space">@ev.Title</MudText>
                                    <AuthorizeView Policy="@Policies.CanEdit" Context="auth">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       Href="@($"/timeline/{ev.Id}/edit")"/>
                                    </AuthorizeView>
                                </div>
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">@ev.DisplayDate</MudText>
                                @if (!string.IsNullOrWhiteSpace(ev.MarkdownBody))
                                {
                                    <div class="markdown-body mt-2">@((MarkupString)Markdown.Render(ev.MarkdownBody))</div>
                                }
                            </MudPaper>
                        }
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</div>

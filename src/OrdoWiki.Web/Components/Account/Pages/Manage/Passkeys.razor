@page "/Account/Manage/Passkeys"

@using System.Buffers.Text
@using Microsoft.AspNetCore.Identity

<PageTitle>Passkeys</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Passkeys</MudText>

<StatusMessage />

<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
    Passkeys let you sign in with your fingerprint, face, or device PIN instead of a password.
</MudText>

@if (CurrentPasskeys is { Count: > 0 })
{
    <MudPaper Elevation="0" Class="mb-4" Outlined="true">
        <MudList T="UserPasskeyInfo">
            @foreach (UserPasskeyInfo passkey in CurrentPasskeys)
            {
                string credentialId = Base64Url.EncodeToString(passkey.CredentialId);
                <MudListItem T="UserPasskeyInfo" Icon="@Icons.Material.Filled.Key">
                    <div class="d-flex align-center" style="width: 100%;">
                        <MudText Class="flex-grow-1">@(passkey.Name ?? "Unnamed passkey")</MudText>
                        <form @formname="@($"update-passkey-{credentialId}")" @onsubmit="UpdatePasskey" method="post" class="d-flex" style="gap: 8px;">
                            <AntiforgeryToken />
                            <input type="hidden" name="CredentialId" value="@credentialId" />
                            <button type="submit" name="Action" value="rename" class="mud-button mud-button-text mud-button-text-primary">Rename</button>
                            <button type="submit" name="Action" value="delete" class="mud-button mud-button-text mud-button-text-error">Delete</button>
                        </form>
                    </div>
                </MudListItem>
            }
        </MudList>
    </MudPaper>
}
else
{
    <MudAlert Severity="Severity.Info" Class="mb-4">No passkeys registered.</MudAlert>
}

<form @formname="add-passkey" @onsubmit="AddPasskey" method="post">
    <AntiforgeryToken />
    @if (CurrentPasskeys is { Count: >= MaxPasskeyCount })
    {
        <MudAlert Severity="Severity.Warning">
            You've reached the maximum of @MaxPasskeyCount passkeys. Delete one before adding another.
        </MudAlert>
    }
    else
    {
        <PasskeySubmit Operation="PasskeyOperation.Create"
                       Name="Input"
                       class="mud-button-root mud-button mud-button-filled mud-button-filled-primary">
            Add a new passkey
        </PasskeySubmit>
    }
</form>

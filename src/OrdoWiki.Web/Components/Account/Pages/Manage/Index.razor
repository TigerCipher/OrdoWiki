@page "/Account/Manage"
@rendermode InteractiveServer

<PageTitle>Profile</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Profile</MudText>

<StatusMessage/>

<form action="/Account/Manage/ProfileUpdate" method="post">
    <AntiforgeryToken/>

    <MudTextField T="string"
                  Value="@Username"
                  Label="Username"
                  Variant="Variant.Outlined"
                  ReadOnly="true"
                  HelperText="Usernames are managed by an administrator."
                  Class="mb-3"/>

    <MudTextField T="string"
                  @bind-Value="DisplayName"
                  Label="Display name"
                  Variant="Variant.Outlined"
                  HelperText="Shown alongside your contributions."
                  Class="mb-4"
                  UserAttributes="@(new Dictionary<string, object?> { ["name"] = "displayName" })"/>

    <MudButton ButtonType="ButtonType.Submit"
               Variant="Variant.Filled"
               Color="Color.Primary">
        Save
    </MudButton>
</form>

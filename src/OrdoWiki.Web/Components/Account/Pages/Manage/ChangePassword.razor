@page "/Account/Manage/ChangePassword"
@rendermode InteractiveServer

<PageTitle>Change password</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Change password</MudText>

@if (MustReset)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        Your password must be changed before you can continue.
    </MudAlert>
}

<form action="/Account/Manage/PasswordChange" method="post">
    <AntiforgeryToken/>

    <MudTextField T="string"
                  @bind-Value="OldPassword"
                  Label="Current password"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  Class="mb-3"
                  UserAttributes="@(new Dictionary<string, object?> { ["name"] = "oldPassword", ["autocomplete"] = "current-password" })"/>

    <MudTextField T="string"
                  @bind-Value="NewPassword"
                  Label="New password"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  HelperText="At least 8 characters."
                  Class="mb-3"
                  UserAttributes="@(new Dictionary<string, object?> { ["name"] = "newPassword", ["autocomplete"] = "new-password" })"/>

    <MudTextField T="string"
                  @bind-Value="ConfirmPassword"
                  Label="Confirm new password"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  Class="mb-4"
                  UserAttributes="@(new Dictionary<string, object?> { ["name"] = "confirmPassword", ["autocomplete"] = "new-password" })"/>

    <MudButton ButtonType="ButtonType.Submit"
               Variant="Variant.Filled"
               Color="Color.Primary">
        Update password
    </MudButton>
</form>

@page "/Account/Login"
@rendermode InteractiveServer

<PageTitle>Sign in</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h4" Class="mb-4">Sign in</MudText>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
        }

        <form action="/Account/PasswordLogin" method="post">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <MudTextField T="string"
                          @bind-Value="Username"
                          Label="Username"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          OnBlur="@Test"
                          UserAttributes="@(new Dictionary<string, object?> { ["name"] = "username", ["autocomplete"] = "username webauthn" })" />

            <MudTextField T="string"
                          @bind-Value="Password"
                          Label="Password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          UserAttributes="@(new Dictionary<string, object?> { ["name"] = "password", ["autocomplete"] = "current-password" })" />

            <MudCheckBox T="bool"
                         @bind-Value="RememberMe"
                         Label="Remember me"
                         Color="Color.Primary"
                         Class="mb-4"
                         UserAttributes="@(new Dictionary<string, object?> { ["name"] = "rememberMe" })" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large">
                Sign in
            </MudButton>
        </form>

        <MudDivider Class="my-4" />

        <PasskeySubmit Operation="PasskeyOperation.Request"
                       Name="Input.Passkey"
                       EmailName="Input.Username"
                       class="mud-button-root mud-button mud-button-text mud-button-text-primary mud-width-full">
            Sign in with a passkey
        </PasskeySubmit>
    </MudPaper>
</MudContainer>

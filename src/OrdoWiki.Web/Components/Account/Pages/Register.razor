@page "/Account/Register"
@rendermode InteractiveServer

<PageTitle>Create your account</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">

        <StatusMessage/>

        @if (Invite is null)
        {
            <MudText Typo="Typo.h4" Class="mb-3">Invitation required</MudText>
            <MudAlert Severity="Severity.Warning">
                Registration is by invite only. The invitation code in your link is missing, expired, or already used.
                Ask an administrator for a fresh invite link.
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.h4" Class="mb-3">Create your account</MudText>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                You're joining as <strong>@Invite.AssignedRole</strong>.
            </MudText>

            <form action="/Account/PasswordRegister" method="post">
                <AntiforgeryToken/>
                <input type="hidden" name="code" value="@Invite.Code"/>

                <MudTextField T="string"
                              @bind-Value="Username"
                              Label="Username"
                              Variant="Variant.Outlined"
                              HelperText="Used to sign in. Letters, numbers, dashes."
                              Class="mb-3"
                              UserAttributes="@(new Dictionary<string, object?> { ["name"] = "username", ["autocomplete"] = "username" })"/>

                <MudTextField T="string"
                              @bind-Value="DisplayName"
                              Label="Display name (optional)"
                              Variant="Variant.Outlined"
                              HelperText="What others will see. Defaults to your username."
                              Class="mb-3"
                              UserAttributes="@(new Dictionary<string, object?> { ["name"] = "displayName" })"/>

                <MudTextField T="string"
                              @bind-Value="Password"
                              Label="Password"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              HelperText="At least 8 characters."
                              Class="mb-3"
                              UserAttributes="@(new Dictionary<string, object?> { ["name"] = "password", ["autocomplete"] = "new-password" })"/>

                <MudTextField T="string"
                              @bind-Value="ConfirmPassword"
                              Label="Confirm password"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              UserAttributes="@(new Dictionary<string, object?> { ["name"] = "confirmPassword", ["autocomplete"] = "new-password" })"/>

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large">
                    Create account
                </MudButton>
            </form>
        }
    </MudPaper>
</MudContainer>

@rendermode InteractiveServer

<MudThemeProvider Theme="_theme" IsDarkMode="@ThemeState.IsDarkMode"/>

@* Inline (not HeadContent) — interactive HeadContent updates have been unreliable for the theme swap. *@
<style id="ordo-theme-vars"
       data-mode="@(ThemeState.IsDarkMode ? "dark" : "light")"
       data-toggles="@ThemeState.ToggleCount">@((MarkupString)_customCss)</style>

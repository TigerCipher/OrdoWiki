<div class="MarkdownEditor y-stack gap-2">
    <MarkdownToolbar @ref="_toolbar"
                     EditorId="@_editorId"
                     Label="@Label"
                     SourceType="@SourceType"
                     SourceId="@SourceId"
                     ShowFullscreen="true"
                     OnFullscreen="@OpenFullscreenAsync"/>

    <div class="split">
        <MudTextField T="string"
                      Value="@_value"
                      ValueChanged="@OnEditorChangedAsync"
                      Variant="Variant.Outlined"
                      Lines="@Lines"
                      MaxLines="@MaxLines"
                      Sizing="InputSizing.Auto"
                      Immediate="true"
                      DebounceInterval="250"
                      Placeholder="@Placeholder"
                      Class="editor-pane"
                      UserAttributes="@(new Dictionary<string, object?> { { "id", _editorId } })"/>

        <MudPaper Outlined="true" Class="preview-pane pa-3">
            @if (string.IsNullOrWhiteSpace(_renderedHtml))
            {
                <MudText Typo="Typo.body2" Color="Color.Tertiary">Preview will appear here</MudText>
            }
            else
            {
                <div class="markdown-body">@((MarkupString)_renderedHtml)</div>
            }
        </MudPaper>
    </div>

    <InputFile id="@_dropInputId"
               style="display:none"
               accept=".jpg,.jpeg,.png,.webp,.gif"
               OnChange="@OnDroppedFileAsync"/>
</div>

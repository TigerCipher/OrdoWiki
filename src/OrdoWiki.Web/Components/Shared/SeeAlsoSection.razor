<div class="SeeAlsoSection y-stack gap-3">
    <MudText Typo="Typo.h5">See also</MudText>

    @if (Value.Characters.Count > 0)
    {
        <div class="group y-stack gap-1">
            <MudText Typo="Typo.subtitle2" Color="Color.Tertiary">Characters</MudText>
            <div class="x-stack gap-1 wrap">
                @foreach (RelatedItemRef item in Value.Characters)
                {
                    <MudChip T="string"
                             Color="Color.Secondary"
                             Variant="Variant.Outlined"
                             Size="Size.Small"
                             Href="@item.Href">
                        @item.Label
                    </MudChip>
                }
            </div>
        </div>
    }

    @if (Value.Logs.Count > 0)
    {
        <div class="group y-stack gap-1">
            <MudText Typo="Typo.subtitle2" Color="Color.Tertiary">Logs</MudText>
            <div class="x-stack gap-1 wrap">
                @foreach (RelatedItemRef item in Value.Logs)
                {
                    <MudChip T="string"
                             Color="Color.Secondary"
                             Variant="Variant.Outlined"
                             Size="Size.Small"
                             Href="@item.Href">
                        @item.Label
                    </MudChip>
                }
            </div>
        </div>
    }

    @if (Value.TimelineEvents.Count > 0)
    {
        <div class="group y-stack gap-1">
            <MudText Typo="Typo.subtitle2" Color="Color.Tertiary">Events</MudText>
            <div class="x-stack gap-1 wrap">
                @foreach (RelatedItemRef item in Value.TimelineEvents)
                {
                    <MudChip T="string"
                             Color="Color.Secondary"
                             Variant="Variant.Outlined"
                             Size="Size.Small"
                             Href="@item.Href">
                        @item.Label
                    </MudChip>
                }
            </div>
        </div>
    }
</div>
